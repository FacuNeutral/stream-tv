{
  "headers": [
    {
      "source": "/telefe-stream.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"telefe-stream.apk\""
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/tokenize", "destination": "/api/tokenize" },
    { "source": "/telefe-stream.apk", "destination": "/telefe-stream.apk" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
